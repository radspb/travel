    <!-- Tailwind Config for Custom Colors -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        sand: {
                            50: '#fdfbf7',
                            100: '#f7f3e8',
                            200: '#eee5ce',
