    <!-- Application Logic -->
    <script>
        // 1. Data Store: Structured data from the Source Report
        const routesData = [
            {
                id: 'route1',
                tabName: 'День 1',
                date: '30 марта',
                title: 'Маршрут 1: Апшеронское кольцо',
                desc: 'Баку — Гобустан — Грязевые вулканы — Атешгях — Янардаг — Баку',
                totalTime: '~3-4 часа',
                specialNote: '⚠️ Дорога к грязевым вулканам грунтовая. В случае дождя воспользуйтесь услугами местных водителей на "Нивах" у музея Гобустана (20-30 манат).',
                steps: [
                    { from: 'Баку', to: 'Гобустан', dist: 65, distLabel: '65 км', time: '~1 час', coords: '40.1118, 49.3695', note: 'Отличное шоссе (E119)' },
                    { from: 'Гобустан', to: 'Грязевые вулканы', dist: 10, distLabel: '10 км', time: '~20 мин', coords: '40.0354, 49.3789', note: 'Грунтовая дорога' },
                    { from: 'Грязевые вулканы', to: 'Атешгях', dist: 80, distLabel: '80 км', time: '~1.5 часа', coords: '40.4521, 50.0085', note: 'Возврат через пр. Гейдара Алиева' },
                    { from: 'Атешгях', to: 'Янардаг', dist: 15, distLabel: '15 км', time: '~25 мин', coords: '40.5019, 49.8912', note: 'Короткий переезд' }
                ]
            },
            {
                id: 'route2',
                tabName: 'День 2',
                date: '31 марта',
                title: 'Маршрут 2: Путь в горы (Шахдаг)',
                desc: 'Баку ➔ гора Бешбармаг ➔ Гусар ➔ Shahdag Mountain Resort',
                totalTime: '~3 часа 30 мин',
                specialNote: '🏔️ В марте на горном серпантине утром возможен гололед. Проверьте зимнюю резину. До Гусара трасса скоростная.',
                steps: [
                    { from: 'Баку', to: 'гора Бешбармаг', dist: 90, distLabel: '90 км', time: '~1 час 15 мин', coords: '40.9576, 49.2291', note: 'Парковка и кафе у подножья' },
                    { from: 'Бешбармаг', to: 'Гусар (поворот)', dist: 90, distLabel: '90 км', time: '~1 час 15 мин', coords: 'Трасса M1', note: 'Движение через Сиязань и Шабран' },
                    { from: 'Гусар', to: 'Шахдаг', dist: 30, distLabel: '30 км', time: '~1 час', coords: 'По указателям', note: 'Горный серпантин (хороший асфальт)' }
                ]
            },
            {
                id: 'route3',
                tabName: 'День 3',
                date: '1 апреля',
                title: 'Маршрут 3: Высокогорная Лаза',
                desc: 'Отель Шахдаг ➔ Село Лаза',
                totalTime: 'Короткая поездка + прогулка',
                specialNote: '🥾 Дорога короткая, но крутая. Оставьте машину на въезде и прогуляйтесь пешком к водопадам (5-10 мин). Отлично для детей.',
                steps: [
                    { from: 'Шахдаг', to: 'Село Лаза', dist: 5, distLabel: '5 км', time: '~15 мин', coords: '41.2965, 48.1147', note: 'Крутой спуск/подъем в ущелье. Парковка на въезде.' }
                ]
            },
            {
                id: 'route4',
                tabName: 'День 4',
                date: '2 апреля',
                title: 'Маршрут 4: Красная Слобода и Гячреш',
                desc: 'Шахдаг ➔ Губа ➔ лес Гячреш ➔ Баку',
                totalTime: '~4 часа',
                specialNote: '⏱️ Рекомендуется выезжать в Баку не позднее 16:00, чтобы избежать плотного трафика на въезде в столицу.',
                steps: [
                    { from: 'Шахдаг', to: 'Губа (Кр. Слобода)', dist: 30, distLabel: '30 км', time: '~40 мин', coords: '41.3712, 48.5147', note: 'Спуск в центр. Прогулка пешком.' },
                    { from: 'Губа', to: 'Лес Гячреш', dist: 12, distLabel: '12 км', time: '~20 мин', coords: '41.3852, 48.4231', note: 'Дорога уходит вглубь леса к реке.' },
                    { from: 'Гячреш', to: 'Баку', dist: 180, distLabel: '180 км', time: '~2.5 часа', coords: 'Трасса M1', note: 'Возврат по основной скоростной трассе.' }
                ]
            }
        ];

        // 2. State Management
        let currentRouteId = routesData[0].id;
        let doughnutChartInstance = null;
        let barChartInstance = null;

        // 3. Initialization
        document.addEventListener('DOMContentLoaded', () => {
            renderTabs();
            renderRouteContent(currentRouteId);
            initBarChart();
        });

        // 4. Core Functions

        // Render Navigation Tabs
        function renderTabs() {
            const tabsContainer = document.getElementById('route-tabs');
            tabsContainer.innerHTML = '';
            
            routesData.forEach(route => {
                const btn = document.createElement('button');
                btn.className = `route-btn flex-1 py-4 px-2 text-center font-medium border-r border-sand-200 last:border-r-0 focus:outline-none ${route.id === currentRouteId ? 'active' : 'text-stone-600'}`;
                btn.innerHTML = `<span class="block text-xs uppercase opacity-75">${route.tabName}</span><span class="block mt-1">${route.date}</span>`;
                btn.onclick = () => {
                    currentRouteId = route.id;
                    updateTabsStyle();
                    renderRouteContent(currentRouteId);
                };
                tabsContainer.appendChild(btn);
            });
        }

        function updateTabsStyle() {
            const buttons = document.querySelectorAll('.route-btn');
            buttons.forEach((btn, index) => {
                if (routesData[index].id === currentRouteId) {
                    btn.classList.add('active');
                    btn.classList.remove('text-stone-600');
                } else {
                    btn.classList.remove('active');
                    btn.classList.add('text-stone-600');
                }
            });
        }

        // Render Dynamic Content based on selected route
        function renderRouteContent(routeId) {
            const route = routesData.find(r => r.id === routeId);
            
            // Text updates
            document.getElementById('display-date').textContent = route.date;
            document.getElementById('display-title').textContent = route.title;
            document.getElementById('display-time').textContent = route.totalTime;
            document.getElementById('display-desc').textContent = route.desc;
            
            const notesEl = document.getElementById('display-notes');
            if (route.specialNote) {
                notesEl.innerHTML = `<strong>Обратите внимание:</strong> ${route.specialNote}`;
                notesEl.classList.remove('hidden');
            } else {
                notesEl.classList.add('hidden');
            }

            // Steps generation
            const stepsContainer = document.getElementById('display-steps');
            stepsContainer.innerHTML = '';
            
            route.steps.forEach((step, index) => {
                const isLast = index === route.steps.length - 1;
                const stepHTML = `
                    <div class="relative">
                        <!-- Connector dot -->
                        <span class="absolute -left-[21px] top-1 h-3 w-3 rounded-full bg-caspian-600 border-2 border-white shadow-sm ring-2 ring-caspian-200"></span>
                        <div class="bg-white border border-sand-100 p-4 rounded-xl shadow-sm hover:shadow-md transition-shadow">
                            <div class="flex justify-between items-start mb-2">
                                <h5 class="font-bold text-stone-800 text-lg">${step.from} ➔ ${step.to}</h5>
                                <span class="bg-sand-100 text-caspian-700 text-xs font-bold px-2 py-1 rounded">${step.distLabel}</span>
                            </div>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm text-stone-600 mt-2">
                                <p><span class="mr-1">⏱️</span> Время: <strong>${step.time}</strong></p>
                                <p class="font-mono text-xs bg-sand-50 p-1 rounded inline-block w-max"><span class="mr-1">🧭</span> ${step.coords}</p>
                            </div>
                            <p class="text-sm mt-3 pt-3 border-t border-sand-100 text-stone-500"><span class="text-flame-500 mr-1">ℹ️</span> ${step.note}</p>
                        </div>
                    </div>
                `;
                stepsContainer.innerHTML += stepHTML;
            });

            // Update Doughnut Chart
            updateDoughnutChart(route);
        }

        // Initialize and Update Doughnut Chart (Chart.js)
        function updateDoughnutChart(route) {
            const ctx = document.getElementById('routeDoughnutChart').getContext('2d');
            
            const labels = route.steps.map(s => `${s.from} - ${s.to}`);
            const dataPoints = route.steps.map(s => s.dist);
            
            // Caspian and Flame inspired palette
            const bgColors = [
                '#0284c7', // caspian-600
                '#ea580c', // flame-600
                '#0ea5e9', // sky-500
                '#fcd34d', // amber-300
                '#94a3b8'  // slate-400
            ];

            if (doughnutChartInstance) {
                doughnutChartInstance.destroy();
            }

            doughnutChartInstance = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: dataPoints,
                        backgroundColor: bgColors.slice(0, dataPoints.length),
                        borderWidth: 2,
                        borderColor: '#ffffff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '65%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                font: { family: "'Segoe UI', sans-serif", size: 12 },
                                color: '#57534e'
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return ` ${context.label}: ${context.raw} км`;
                                }
                            },
                            backgroundColor: 'rgba(28, 25, 23, 0.9)',
                            padding: 12,
                            cornerRadius: 8
                        }
                    }
                }
            });
        }

        // Initialize Bar Chart for total mileage (Chart.js)
        function initBarChart() {
            const ctx = document.getElementById('mileageBarChart').getContext('2d');
            
            // Calculate total distances per route
            const totalDistances = routesData.map(route => {
                return route.steps.reduce((sum, step) => sum + step.dist, 0);
            });
            const labels = routesData.map(r => r.tabName + ' (' + r.date + ')');

            barChartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Общий пробег за день (км)',
                        data: totalDistances,
                        backgroundColor: '#0369a1', // caspian-700
                        borderRadius: 6,
                        hoverBackgroundColor: '#ea580c' // flame-600
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#e7e5e4', borderDash: [5, 5] },
                            ticks: { color: '#78716c', font: {family: "'Segoe UI', sans-serif"} },
                            title: { display: true, text: 'Километры', color: '#78716c' }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#57534e', font: {family: "'Segoe UI', sans-serif", weight: 'bold'} }
                        }
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(28, 25, 23, 0.9)',
                            padding: 12,
                            cornerRadius: 8,
                            callbacks: {
                                label: function(context) {
                                    return ` Пробег: ${context.raw} км`;
                                }
                            }
                        }
                    }
                }
            });
        }
    </script>
</body>
</html>
